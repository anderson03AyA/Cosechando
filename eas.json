{
  "cli": {
    "version": ">= 2.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FORCE_TEST_ADS": "true",
        "EXPO_PUBLIC_UPDATE_CONFIG_URL": "https://raw.githubusercontent.com/anderson03AyA/update-config.json/main/update-config.json"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FORCE_TEST_ADS": "true",
        "EXPO_PUBLIC_UPDATE_CONFIG_URL": "https://raw.githubusercontent.com/anderson03AyA/update-config.json/main/update-config.json"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FORCE_TEST_ADS": "false",
        "EXPO_PUBLIC_UPDATE_CONFIG_URL": "https://raw.githubusercontent.com/anderson03AyA/update-config.json/main/update-config.json"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_FORCE_TEST_ADS": "false",
        "EXPO_PUBLIC_UPDATE_CONFIG_URL": "https://raw.githubusercontent.com/anderson03AyA/update-config.json/main/update-config.json"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
